  "module": "bin/square.ts",
  "type": "module",
  "license": "MIT",
  "author": "karthikdilliraj",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karthikdilliraj/square-sdk-cli.git"
  },
  "homepage": "https://github.com/karthikdilliraj/square-sdk-cli#readme",
  "bugs": "https://github.com/karthikdilliraj/square-sdk-cli/issues",
